      <category>我的世界</category>
      
    </categories>
    
    
    <tags>
      
      <tag>我的世界mod教程</tag>
      
    </tags>
    
  </entry>
  
  
  
  <entry>
    <title>华为交换机基础配置</title>
    <link href="/2023/05/30/%E5%8D%8E%E4%B8%BA%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%9F%BA%E7%A1%80%E9%85%8D%E7%BD%AE/"/>
    <url>/2023/05/30/%E5%8D%8E%E4%B8%BA%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%9F%BA%E7%A1%80%E9%85%8D%E7%BD%AE/</url>
    
    <content type="html"><![CDATA[<h1 id="基础配置命令">基础配置命令</h1><p>启动后进入交换机</p><h2 id="设置中文提示">设置中文提示</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-qild46lih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-qild46lih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">language-mode Chinese<br></code></pre></td></tr></tbody></table></div></figure><h2 id="进入系统视图">进入系统视图</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-1uge3llih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-1uge3llih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">system-view<br></code></pre></td></tr></tbody></table></div></figure><h2 id="用户权限">用户权限</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-0j9qb2lih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-0j9qb2lih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">user privilege level 15<br></code></pre></td></tr></tbody></table></div></figure><h2 id="进入console配置">进入console配置</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-slaiaslih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-slaiaslih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">user-interface console 0<br></code></pre></td></tr></tbody></table></div></figure><h2 id="设置console密码">设置console密码</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-4gyguelih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-4gyguelih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><code class="hljs switch">authentication-mode password<br>set authentication password simple Huawei<br></code></pre></td></tr></tbody></table></div></figure><h2 id="设置登录前后标语">设置登录前后标语</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-vv2ncolih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-vv2ncolih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><code class="hljs switch">header login information "This is SW1"<br>header shell information "login succeed"<br></code></pre></td></tr></tbody></table></div></figure><h2 id="创建与划分vlan">创建与划分vlan</h2><h3 id="创建vlan">创建vlan</h3><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-t3his4lih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-t3his4lih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">vlan batch 10 20<br></code></pre></td></tr></tbody></table></div></figure><h3 id="进入端口并划分vlan">进入端口并划分vlan</h3><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-61p6tnlih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-61p6tnlih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><code class="hljs switch">interface GigabitEthernet 0/0/1<br>port link-type access<br>port default vlan 10<br></code></pre></td></tr></tbody></table></div></figure><h2 id="设置vlan-ip">设置vlan IP</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-55bsg6lih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-55bsg6lih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><code class="hljs switch">interface vlanif 10<br>ip address 192.168.10.1 24<br></code></pre></td></tr></tbody></table></div></figure><h2 id="查看配置结果">查看配置结果</h2><figure class="highlight plaintext"><i class="iconfont icon-icon-down" type="button" data-toggle="collapse" data-target="#collapse-ag86lhlih2thxd"></i><span>switch</span><div class="collapse show" id="collapse-ag86lhlih2thxd"><table><tbody><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs switch">display current-configuration<br></code></pre></td></tr></tbody></table></div></figure>]]></content>
    
    
